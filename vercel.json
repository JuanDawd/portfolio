{
	"buildCommand": "pnpm run build",
	"outputDirectory": "dist",
	"framework": "vite",
	"rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
	"headers": [
		{
			"source": "/resume/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/2025/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
